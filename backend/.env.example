# OpenRouter AI — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# Tavily Search — https://app.tavily.com
TAVILY_API_KEY=tvly-...

# Hedera Network — https://portal.hedera.com
HEDERA_ACCOUNT_ID=0.0.12345
HEDERA_PRIVATE_KEY=302e...
HEDERA_NETWORK=testnet
HCS_TOPIC_ID=0.0.98765

# Supabase — https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:4028

# Server port (Railway sets this automatically)
PORT=8000
