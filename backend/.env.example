# OpenRouter AI - https://openrouter.ai
# Sign up and get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Tavily Search - https://tavily.com
# Sign up and get your API key from: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# Hedera Network Configuration
# For testnet: Get account and key from https://portal.hedera.com
# For mainnet: Use your existing mainnet account
HEDERA_ACCOUNT_ID=0.0.12345
HEDERA_PRIVATE_KEY=302e... (hex-encoded 32-byte private key)
HEDERA_NETWORK=testnet
HCS_TOPIC_ID=0.0.98765

# Supabase - https://supabase.com
# Get these from your Supabase project settings
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_JWT_SECRET=<jwt-secret>

# CORS - Allowed origins for frontend requests
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:4028,http://localhost:3000

# Server Configuration
PORT=8000

# Database Configuration (optional, defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@localhost/dbname
